---
layout: base.njk
title: Home
description: Ace Strategies provides expert strategic communications, government relations, and stakeholder engagement. Based in Adelaide, South Australia.
active_nav: /
permalink: /index.html
---
{% import "macros/client-marquee.njk" as marquee %}
{% import "macros/service-capability-card.njk" as serviceCard %}
{% import "macros/team-flip-card.njk" as teamCard %}
{% import "macros/news-article-card.njk" as newsCard %}
{% import "macros/testimonial-card.njk" as testimonialCard %}
{% import "macros/cta-section.njk" as cta %}

{# HERO SECTION #}
<section class="hero hero--home" data-theme="dark">
  <div class="hero-media">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster="/assets/repository/images/ui/background/hero-poster.jpg">
      <source src="/assets/repository/videos/homepage-bq.mp4" type="video/mp4">
    </video>
  </div>
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="word"><span><em>Navigate</em></span></span>
      <span class="word"><span>the</span></span>
      <span class="word"><span><em>complex</em></span></span>
      <span class="word"><span>world.</span></span>
    </h1>
    <p class="hero-subtitle">
      Ace Strategies provides expert guidance to help your organisation succeed. Based in Adelaide, South Australia, we specialise in integrated strategic communications, government relations, and stakeholder engagement.
    </p>
    <div class="hero-cta-wrapper">
      <a href="/contact/" class="hero-cta-circle"><span>Start the<br>Conversation<br>today</span></a>
    </div>
  </div>
</section>

{# STRATEGIC CAPABILITIES CAROUSEL #}
<section class="services-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">What We Do</span>
    <h2 class="section-title">Strategic Capabilities</h2>
    <div class="section-divider"></div>
  </div>
  <div class="carousel-container-outer">
    <button class="carousel-nav-btn prev-btn" id="cap-prev" aria-label="Previous capability">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <div class="carousel-wrapper">
      <div class="services-carousel-track" id="capabilities-carousel">
        {% for service in capabilities %}
        {{ serviceCard.card(service) }}
        {% endfor %}
      </div>
    </div>
    <button class="carousel-nav-btn next-btn" id="cap-next" aria-label="Next capability">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
  </div>
  <div class="carousel-dots" id="cap-dots"></div>
</section>

{# TRUSTED BY MARQUEE #}
<section class="logo-section" data-theme="light">
  <div class="section-header" style="margin-bottom:32px;">
    <span class="section-label">Trusted By</span>
  </div>
  {{ marquee.marquee(clients, '/assets/repository/images/clients/', '90s', true) }}
</section>

{# TESTIMONIALS CAROUSEL #}
<section class="testimonials-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Client Perspectives</span>
    <h2 class="section-title">Partners in Impact</h2>
    <div class="section-divider"></div>
  </div>
  <div class="carousel-container-outer">
    <button class="carousel-nav-btn prev-btn" id="test-prev" aria-label="Previous testimonial">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <div class="testimonials-carousel-wrapper">
      <div class="testimonials-track" id="testimonials-carousel">
        {% for item in testimonials %}
        {{ testimonialCard.card(item.quote, item.author, item.role) }}
        {% endfor %}
      </div>
    </div>
    <button class="carousel-nav-btn next-btn" id="test-next" aria-label="Next testimonial">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
  </div>
  <div class="carousel-dots" id="test-dots"></div>
</section>

{# MEET THE TEAM #}
<section class="team-teaser-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Leadership</span>
    <h2 class="section-title">Meet the Ace Team</h2>
    <div class="section-divider"></div>
  </div>
  <div class="team-grid">
    {% for member in collections.teamMembers %}
    {{ teamCard.card(member) }}
    {% endfor %}
  </div>
</section>

{# NEWS CAROUSEL #}
<section class="news-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Latest Insights</span>
    <h2 class="section-title">News &amp; Analysis</h2>
    <div class="section-divider"></div>
  </div>
  <div class="carousel-container-outer">
    <button class="carousel-nav-btn prev-btn" id="news-prev" aria-label="Previous news item">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <div class="news-carousel-wrapper">
      <div class="news-carousel-track" id="news-carousel">
        {% for article in collections.news %}
        {{ newsCard.card(article, 'carousel') }}
        {% endfor %}
      </div>
    </div>
    <button class="carousel-nav-btn next-btn" id="news-next" aria-label="Next news item">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
  </div>
  <div class="carousel-dots" id="news-dots"></div>
</section>

{# PROFESSIONAL AFFILIATIONS #}
<section class="membership-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Professional Affiliations</span>
    <h2 class="section-title">Industry Leadership</h2>
    <div class="section-divider"></div>
  </div>
  {{ marquee.marquee(affiliations, '/assets/repository/images/clients/', '90s', true) }}
</section>

{# CTA #}
{{ cta.section("Ready to achieve clarity and impact?", 'Contact us today', '/contact/', 'Partner with Ace Strategies.', 'dark', 'clarity and impact?') }}

---
layout: base.njk
title: News & Insights
description: Latest polling data, strategic analysis, and corporate announcements from Ace Strategies.
active_nav: /news/
permalink: /news/index.html
---
{% import "macros/polling-bar.njk" as pollingMacro %}
{% import "macros/news-article-card.njk" as newsCard %}
{% import "macros/newsletter-signup.njk" as newsletter %}
{% import "macros/cta-section.njk" as cta %}

<section class="news-hero" data-theme="dark">
  <div class="news-hero-content">
    <h1 class="hero-title">Market Intelligence <span style="font-family:var(--font-serif);font-style:italic;color:var(--sky-blue);">&amp; Insights</span></h1>
    <p class="hero-subtitle">Polling data, strategic analysis, and company announcements.</p>
  </div>
</section>

<section class="polling-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Exclusive Polling</span>
    <h2 class="section-title">South Australia: The Political Pulse</h2>
    <div class="section-divider"></div>
  </div>
  {{ pollingMacro.pollingBar(polling.south_australia, 'Source: DemosAU / Ace Strategies', polling._fallback) }}
</section>

<section class="news-articles-section" data-theme="light">
  <div class="section-header">
    <span class="section-label">Latest Releases</span>
    <h2 class="section-title">News &amp; Announcements</h2>
    <div class="section-divider"></div>
  </div>
  <div class="news-grid" style="max-width:var(--max-width);margin:0 auto;padding:0 40px 60px;display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:32px;">
    {% for item in collections.news %}
    {{ newsCard.card(item, 'grid') }}
    {% endfor %}
  </div>
</section>

<section class="newsletter-section" data-theme="light" style="background:#fafafa;padding:60px 20px;">
  <div style="max-width:640px;margin:0 auto;text-align:center;">
    {{ newsletter.signup('Stay ahead of the intelligence', 'Get exclusive polling data and strategic analysis direct to your inbox.', 'Subscribe') }}
  </div>
</section>

{{ cta.section('Stay ahead with Ace intelligence.', 'Contact us today', '/contact/', '', 'dark', 'Ace intelligence.') }}

<script>
(function () {
  fetch('/api/polling.json')
    .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function (d) {
      var labor = document.getElementById('poll-bar-labor');
      var liberal = document.getElementById('poll-bar-liberal');
      var badge = document.getElementById('poll-fallback-badge');
      if (!labor || !liberal) return;
      labor.dataset.value = d.labor_tpp;
      labor.textContent = 'ALP ' + d.labor_tpp + '%';
      liberal.dataset.value = d.liberal_tpp;
      liberal.textContent = 'LIB ' + d.liberal_tpp + '%';
      if (badge) badge.innerHTML = '';
    })
    .catch(function () {});
}());
</script>

---
layout: iaa-base.njk
title: Invest Australia Alliance
description: Enter the Australian market with certainty. The Invest Australia Alliance delivers strategic intelligence, regulatory expertise, and operational infrastructure for international businesses.
active_nav: /alliance/
permalink: /alliance/index.html
---

<main class="iaa-canvas">

  <header class="iaa-hero-editorial">
    <div class="iaa-hero-content" data-iaa-reveal>
      <span class="iaa-superhead">Invest Australia Alliance</span>
      <h1 class="iaa-display-title">Enter the Australian market with certainty.</h1>
      <p class="iaa-lead-text">Invest Australia Alliance delivers the strategic intelligence, regulatory expertise, and operational infrastructure international businesses require for accelerated Australian market entry.</p>
      <div class="iaa-hero-actions">
        <a href="/contact/" class="btn-iaa-primary">Discuss strategy</a>
        <a href="#capabilities" class="btn-iaa-text">Explore capabilities &rarr;</a>
      </div>
    </div>
    <div class="iaa-hero-visual" data-iaa-reveal>
      <div class="iaa-video-frame">
        <video autoplay muted loop playsinline preload="metadata">
          <source src="/assets/repository/videos/iaa.mp4" type="video/mp4">
        </video>
      </div>
    </div>
  </header>

  <div class="iaa-marquee-strip" data-iaa-reveal>
    {% import "macros/client-marquee.njk" as marquee %}
    {{ marquee.marquee(partners, '/assets/repository/images/clients/', '60s', false) }}
  </div>

  <section class="iaa-editorial-section" id="capabilities">
    <div class="iaa-container">
      <div class="iaa-section-intro" data-iaa-reveal>
        <span class="iaa-superhead">Methodology</span>
        <h2 class="iaa-section-title">The Alliance advantage</h2>
        <p class="iaa-section-desc">We combine boutique consultancy responsiveness with the comprehensive capabilities of a vetted partner network spanning legal, financial, operational, and strategic domains. From environmental analysis and government relations to facility establishment and talent acquisition, we de-risk your expansion and position you for sustained commercial success.</p>
      </div>

      <div class="iaa-grid-3">
        <div class="iaa-grid-item">
          <h3 class="iaa-item-title">Agile</h3>
          <p class="iaa-item-text">Direct access to senior strategists who understand your sector and timeline constraints. No account management layers, no scope creep, no extended discovery phases.</p>
        </div>
        <div class="iaa-grid-item">
          <h3 class="iaa-item-title">Connected</h3>
          <p class="iaa-item-text">Immediate access to decision-makers across Commonwealth and state jurisdictions, plus established relationships with regulatory bodies, industry associations, and commercial gatekeepers.</p>
        </div>
        <div class="iaa-grid-item">
          <h3 class="iaa-item-title">Comprehensive</h3>
          <p class="iaa-item-text">Full-spectrum capability through our alliance of sector leaders—each vetted for domain expertise and client-first values. Legal capabilities, banking relationships, facility identification, talent solutions, and strategic communications, coordinated through a single point of accountability.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <span class="iaa-superhead" data-iaa-reveal>Capabilities</span>
      <h2 class="iaa-section-title" data-iaa-reveal>Service architecture</h2>
      <div class="iaa-grid-2">
        <div class="iaa-service-item">
          <span class="iaa-service-num">01.</span>
          <div class="iaa-service-content">
            <h3 class="iaa-item-title">Strategic advisory</h3>
            <p class="iaa-item-text">Political risk analysis, government relations strategy, stakeholder mapping, and B2G engagement planning.</p>
          </div>
        </div>
        <div class="iaa-service-item">
          <span class="iaa-service-num">02.</span>
          <div class="iaa-service-content">
            <h3 class="iaa-item-title">Market intelligence</h3>
            <p class="iaa-item-text">Competitor analysis, procurement pathway identification, sovereign capability alignment, and public sentiment polling.</p>
          </div>
        </div>
        <div class="iaa-service-item">
          <span class="iaa-service-num">03.</span>
          <div class="iaa-service-content">
            <h3 class="iaa-item-title">Regulatory & compliance</h3>
            <p class="iaa-item-text">Foreign Investment Review Board (FIRB) navigation, taxation structuring, employment law, and visa and migration support.</p>
          </div>
        </div>
        <div class="iaa-service-item">
          <span class="iaa-service-num">04.</span>
          <div class="iaa-service-content">
            <h3 class="iaa-item-title">Operational establishment</h3>
            <p class="iaa-item-text">Site selection, commercial leasing, talent acquisition, supply chain qualification, and in-country representation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <div class="iaa-section-intro" data-iaa-reveal>
        <span class="iaa-superhead">Execution</span>
        <h2 class="iaa-section-title">The engagement model</h2>
        <p class="iaa-section-desc">A phased approach designed to minimise risk and maximise speed to market.</p>
      </div>

      <div class="iaa-timeline">
        <div class="iaa-timeline-item" data-iaa-reveal>
          <div class="iaa-timeline-bg">01</div>
          <div class="iaa-timeline-content">
            <h3 class="iaa-item-title">Discovery & diagnostics</h3>
            <p class="iaa-item-text">We audit your readiness, identify critical gaps, and map the regulatory and political landscape specific to your product or service.</p>
          </div>
        </div>
        <div class="iaa-timeline-item" data-iaa-reveal>
          <div class="iaa-timeline-bg">02</div>
          <div class="iaa-timeline-content">
            <h3 class="iaa-item-title">Strategy & sequencing</h3>
            <p class="iaa-item-text">Development of a phased market entry plan, including partner selection, capital requirements, and stakeholder engagement timelines.</p>
          </div>
        </div>
        <div class="iaa-timeline-item" data-iaa-reveal>
          <div class="iaa-timeline-bg">03</div>
          <div class="iaa-timeline-content">
            <h3 class="iaa-item-title">Execution & integration</h3>
            <p class="iaa-item-text">Activation of the alliance network. Entity setup, recruitment, lobbying, and commercial launch supported by on-ground experts.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <span class="iaa-superhead" data-iaa-reveal>The Network</span>
      <h2 class="iaa-section-title" data-iaa-reveal>Alliance Index</h2>

      <div class="iaa-index-wrapper">
        {% for partner in iaaPartners %}
        <div class="iaa-index-row">
          <div class="iaa-index-cat">{{ partner.category }}</div>
          <div class="iaa-index-name">{{ partner.name }}</div>
          <div class="iaa-index-desc">{{ partner.desc }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="iaa-editorial-cta" id="contact" data-iaa-reveal>
    <div class="iaa-cta-box">
      <h2 class="iaa-display-title" style="font-size:2.25rem;">Ready to explore the market?</h2>
      <p class="iaa-lead-text" style="max-width:600px; margin: 0 auto 40px;">Contact the Alliance to discuss your strategic objectives. We will assess your requirements and propose a tailored engagement framework.</p>
      <a href="/contact/" class="btn-iaa-primary">Initiate Contact</a>
    </div>
  </section>

</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navBar = document.querySelector('.nav');
    let scrollTimeout;

    window.addEventListener('scroll', () => {
      if (!navBar.classList.contains('is-scrolling')) {
        navBar.classList.add('is-scrolling');
      }
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        navBar.classList.remove('is-scrolling');
      }, 200);
    }, { passive: true });

    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      gsap.fromTo('.iaa-video-frame',
        { scale: 0.95, y: 30 },
        { scale: 1, y: 0, ease: 'power3.out', duration: 1.5, scrollTrigger: { trigger: '.iaa-hero-editorial', start: 'top 80%' } }
      );

      gsap.to('.iaa-video-frame video', {
        yPercent: 15, ease: 'none',
        scrollTrigger: { trigger: '.iaa-hero-editorial', start: 'top top', end: 'bottom top', scrub: true }
      });

      const grids = document.querySelectorAll('.iaa-grid-3, .iaa-grid-2');
      grids.forEach(grid => {
        const items = grid.querySelectorAll('.iaa-grid-item, .iaa-service-item');
        gsap.fromTo(items, { y: 40, opacity: 0 }, { y: 0, opacity: 1, duration: 1.2, stagger: 0.12, ease: 'power3.out', scrollTrigger: { trigger: grid, start: 'top 85%' } });
      });

      const indexWrapper = document.querySelector('.iaa-index-wrapper');
      if (indexWrapper) {
        const rows = indexWrapper.querySelectorAll('.iaa-index-row');
        gsap.fromTo(rows, { x: -20, opacity: 0 }, { x: 0, opacity: 1, duration: 0.8, stagger: 0.05, ease: 'power2.out', scrollTrigger: { trigger: indexWrapper, start: 'top 85%' } });
      }

      document.querySelectorAll('[data-iaa-reveal]').forEach(el => {
        if (el.closest('.iaa-grid-3') || el.closest('.iaa-grid-2') || el.classList.contains('iaa-index-row') || el.classList.contains('iaa-hero-visual')) return;
        gsap.fromTo(el, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1.2, ease: "power3.out", scrollTrigger: { trigger: el, start: "top 85%" } });
      });
    }
  });
</script>
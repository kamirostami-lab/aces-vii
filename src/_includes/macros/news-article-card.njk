{% macro card(item, variant = 'carousel') %}
{% if variant == 'carousel' %}
<div class="news-text-card">
  <div class="news-date">{{ item.data.date | dateFormat }}</div>
  <h3 class="news-card-title">{{ item.data.title }}</h3>
  <p class="news-snippet">{{ item.data.excerpt }}</p>
  <a href="/news/" class="news-read-link">Read more</a>
</div>
{% else %}
<article class="news-item">
  {% if item.data.image %}
  <img src="{{ item.data.image }}" alt="{{ item.data.image_alt }}" class="news-item-img" loading="lazy">
  {% endif %}
  <div class="news-item-body">
    <div style="font-size:0.75rem;color:#999;text-transform:uppercase;margin-bottom:8px;">{{ item.data.date | dateFormat }}</div>
    <h3 style="font-family:var(--font-serif);font-size:1.5rem;color:var(--navy);margin-bottom:15px;">{{ item.data.title }}</h3>
    <p style="font-size:0.95rem;color:var(--navy);line-height:1.6;">{{ item.data.excerpt }}</p>
    {% if item.content %}
    <details>
      <summary>Read full release</summary>
      <div class="expanded-content">
        {{ item.content | safe }}
        {% if item.data.pdf_url %}
        <a href="{{ item.data.pdf_url }}" target="_blank" style="color:var(--sky-blue);font-weight:700;">
          {{ item.data.pdf_label | default('Download PDF Announcement') }}
        </a>
        {% endif %}
      </div>
    </details>
    {% endif %}
  </div>
</article>
{% endif %}
{% endmacro %}

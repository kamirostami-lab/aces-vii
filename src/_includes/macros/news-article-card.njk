{# 
  News Article Card Macro
  @param {Object} article - News article object
  @param {String} variant - 'carousel' (default) or 'grid'
#}
{% macro card(article, variant = 'carousel') %}
{% if variant == 'carousel' %}
{# Carousel variant (text-only card) #}
<div class="news-text-card">
  <div class="news-date">{{ article.date | dateFormat }}</div>
  <h3 class="news-card-title">{{ article.title }}</h3>
  <p class="news-snippet">{{ article.excerpt }}</p>
  <a href="{{ article.url | default('/news/') }}" class="news-read-link">
    {{ article.link_text | default('Read more') }}
  </a>
</div>
{% else %}
{# Grid variant (with image, for news page) #}
<article class="news-item">
  {% if article.image %}
  <img src="{{ article.image }}" alt="{{ article.image_alt }}" class="news-item-img" loading="lazy">
  {% endif %}
  <div class="news-item-body">
    <div style="font-size:0.75rem;color:#999;text-transform:uppercase;margin-bottom:8px;">
      {{ article.date | dateFormat }}
    </div>
    <h3 style="font-family:var(--font-serif);font-size:1.5rem;color:var(--navy);margin-bottom:15px;">
      {{ article.title }}
    </h3>
    <p style="font-size:0.95rem;color:var(--navy);line-height:1.6;">{{ article.excerpt }}</p>
    
    {% if article.body_paragraphs %}
    <details>
      <summary>Read full release</summary>
      <div class="expanded-content">
        {% for para in article.body_paragraphs %}
        <p>{{ para }}</p>
        {% endfor %}
        {% if article.pdf_url %}
        <a href="{{ article.pdf_url }}" target="_blank" style="color:var(--sky-blue);font-weight:700;">
          {{ article.pdf_label | default('Download PDF Announcement') }}
        </a>
        {% endif %}
      </div>
    </details>
    {% endif %}
  </div>
</article>
{% endif %}
{% endmacro %}
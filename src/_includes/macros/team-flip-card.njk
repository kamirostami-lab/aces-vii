{% macro card(item) %}
<div class="team-card">
  <div class="team-card-inner">
    <div class="team-card-front">
      <img src="{{ item.data.image_index }}" alt="{{ item.data.image_alt_index }}" loading="lazy">
      <div class="team-info-overlay">
        <h3 class="team-name">{{ item.data.name }}</h3>
        <div class="team-role">{{ item.data.role }}</div>
      </div>
    </div>
    <div class="team-card-back">
      <p class="team-bio">{{ item.data.bio_short }}</p>
      <a href="/team/#{{ item.data.id }}" class="team-social-btn">Read more</a>
    </div>
  </div>
</div>
{% endmacro %}

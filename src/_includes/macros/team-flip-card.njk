{# 
  Team Member Flip Card Macro (for homepage)
  @param {Object} member - Team member object with all properties
#}
{% macro card(member) %}
<div class="team-card">
  <div class="team-card-inner">
    <div class="team-card-front">
      <img src="{{ member.image_index }}" alt="{{ member.image_alt_index }}" loading="lazy">
      <div class="team-info-overlay">
        <h3 class="team-name">{{ member.name }}</h3>
        <div class="team-role">{{ member.role }}</div>
      </div>
    </div>
    <div class="team-card-back">
      <p class="team-bio">{{ member.bio_short }}</p>
      <a href="/team/#{{ member.id }}" class="team-social-btn">Read more</a>
    </div>
  </div>
</div>
{% endmacro %}
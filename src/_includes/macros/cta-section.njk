{# 
  CTA Section Macro
  @param {String} title - Main heading text (supports HTML)
  @param {String} subtitle - Optional subtitle text
  @param {String} buttonText - Button text
  @param {String} buttonUrl - Button destination URL
  @param {String} theme - 'dark' (default) or 'light'
  @param {String} highlightText - Text to highlight (wrapped in <span class="highlight">)
#}
{% macro section(title, buttonText = 'Contact us today', buttonUrl = '/contact/', subtitle = '', theme = 'dark', highlightText = 'clarity and impact?') %}
<section class="cta-section" data-theme="{{ theme }}">
  <div class="cta-content">
    <h2 class="cta-title">
      {% if highlightText %}
      {{ title | replace(highlightText, '<span class="highlight">' + highlightText + '</span>') | safe }}
      {% else %}
      {{ title | safe }}
      {% endif %}
    </h2>
    {% if subtitle %}
    <p class="cta-sub">{{ subtitle }}</p>
    {% endif %}
    <a href="{{ buttonUrl }}" class="cta-button">{{ buttonText }}</a>
  </div>
</section>
{% endmacro %}
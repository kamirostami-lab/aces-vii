{# 
  Testimonial Card Macro
  @param {String} quote - The testimonial quote text
  @param {String} author - The author's name
  @param {String} role - The author's role/company
  @param {Boolean} isCaseStudy - Whether this is styled as a case study quote (default: false)
#}
{% macro card(quote, author, role, isCaseStudy = false) %}
{% if isCaseStudy %}
{# Case Study Quote Variant #}
<div class="case-quote-box">
  <blockquote class="case-quote">&ldquo;{{ quote | safe }}&rdquo;</blockquote>
  <cite class="case-author">{{ author }} — {{ role }}</cite>
</div>
{% else %}
{# Standard Testimonial Card Variant #}
<div class="testimonial-card">
  <div class="quote-icon">&ldquo;</div>
  <blockquote class="testimonial-quote">{{ quote | safe }}</blockquote>
  <div class="testimonial-author">
    <cite class="author-name">{{ author }}</cite>
    <span class="author-role">{{ role }}</span>
  </div>
</div>
{% endif %}
{% endmacro %}
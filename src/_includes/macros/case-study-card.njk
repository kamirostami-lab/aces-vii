{# 
  Case Study Card Macro
  @param {Object} case - Case study object with all properties
#}
{% macro card(case) %}
<article class="case-study-card">
  <div class="case-media">
    <img src="{{ case.image }}" alt="{{ case.image_alt }}" loading="lazy">
  </div>
  <div class="case-content">
    <span class="case-category">{{ case.category }}</span>
    <h2 class="case-client">{{ case.client }}</h2>
    <h3 class="case-title">{{ case.title }}</h3>
    <div class="case-body">
      {% for para in case.body_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
    {% if case.has_quote and case.quote %}
    <div class="case-quote-box">
      <blockquote class="case-quote">&ldquo;{{ case.quote }}&rdquo;</blockquote>
      <cite class="case-author">{{ case.quote_author }}</cite>
    </div>
    {% endif %}
  </div>
</article>
{% endmacro %}
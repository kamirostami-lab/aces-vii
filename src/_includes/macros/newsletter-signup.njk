{% macro newsletterSignup(title, description, buttonText) %}
<div class="newsletter-signup">
  <div class="newsletter-signup__content">
    {% if title %}
    <h3 class="newsletter-signup__title">{{ title }}</h3>
    {% endif %}
    {% if description %}
    <p class="newsletter-signup__description">{{ description }}</p>
    {% endif %}
  </div>
  <form class="newsletter-signup__form" action="https://app.convertkit.com/forms/REPLACE_WITH_YOUR_FORM_ID/subscriptions" method="post">
    <div class="newsletter-signup__input-group">
      <input type="text" name="first_name" placeholder="First name" aria-label="First name">
      <input type="email" name="email_address" placeholder="Email address" aria-label="Email address" required>
      <button type="submit">{{ buttonText or 'Subscribe' }}</button>
    </div>
    <p class="newsletter-signup__privacy">We respect your privacy. Unsubscribe at any time.</p>
  </form>
</div>
{% endmacro %}

{# 
  Newsletter Signup Macro
  @param {String} title - Optional heading text
  @param {String} description - Optional description text
  @param {String} buttonText - Button text (default: 'Subscribe')
  @param {String} variant - 'full' (default) or 'compact' (for footer)
  @param {String} formId - ConvertKit form ID (default: '1e8eda3139')
#}
{% macro signup(title = '', description = '', buttonText = 'Subscribe', variant = 'full', formId = '1e8eda3139') %}
{% if variant == 'compact' %}
{# Compact Footer Variant #}
<div class="footer-newsletter">
  {% if title %}
  <h4>{{ title }}</h4>
  {% endif %}
  {% if description %}
  <p>{{ description }}</p>
  {% endif %}
  <form class="footer-newsletter-form" action="https://app.convertkit.com/forms/{{ formId }}/subscriptions" method="post">
    <input type="email" name="email_address" placeholder="Your email" aria-label="Email address" required>
    <button type="submit">{{ buttonText }}</button>
  </form>
</div>
{% else %}
{# Full Page/Section Variant #}
<div class="newsletter-signup">
  <div class="newsletter-signup__content">
    {% if title %}
    <h3 class="newsletter-signup__title">{{ title }}</h3>
    {% endif %}
    {% if description %}
    <p class="newsletter-signup__description">{{ description }}</p>
    {% endif %}
  </div>
  <form class="newsletter-signup__form" action="https://app.convertkit.com/forms/{{ formId }}/subscriptions" method="post">
    <div class="newsletter-signup__input-group">
      <input type="text" name="first_name" placeholder="First name" aria-label="First name">
      <input type="email" name="email_address" placeholder="Email address" aria-label="Email address" required>
      <button type="submit">{{ buttonText }}</button>
    </div>
    <p class="newsletter-signup__privacy">We respect your privacy. Unsubscribe at any time.</p>
  </form>
</div>
{% endif %}
{% endmacro %}
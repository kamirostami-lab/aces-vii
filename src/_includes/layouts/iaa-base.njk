<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Invest Australia Alliance</title>
  <meta name="description" content="{{ description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="/assets/css/ace.css">
</head>
<body class="iaa-page">

<nav class="nav">
  <a href="/alliance/" class="logo"><img src="/assets/repository/images/ui/iaa.webp" alt="Invest Australia Alliance"></a>
  <ul class="nav-menu">
    <li><a href="/" class="nav-link">Ace Strategies</a></li>
    <li><a href="/alliance/" class="nav-link active">Alliance</a></li>
    <li><a href="/contact/" class="nav-link">Contact</a></li>
  </ul>
</nav>

{{ content | safe }}

<footer class="site-footer">
  <div class="footer-content">
    <p>&copy; {% year %} Invest Australia Alliance</p>
  </div>
</footer>

</body>
</html>

<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Invest Australia Alliance</title>
  <meta name="description" content="{{ description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="/src/assets/css/ace.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body class="iaa-page">

<nav class="nav">
  <a href="/alliance/" class="logo"><img src="/src/assets/repository/images/ui/iaa.webp" alt="Invest Australia Alliance"></a>
  <ul class="nav-menu">
    <li><a href="/" class="nav-link">Ace Strategies</a></li>
    <li><a href="/alliance/" class="nav-link {% if page.url == '/alliance/' %}active{% endif %}">Alliance</a></li>
    <li><a href="/contact/" class="nav-link">Contact</a></li>
  </ul>
  <button class="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

{{ content | safe }}

<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-grid">
      <div class="footer-section">
        <img src="/src/assets/repository/images/ui/iaa.webp" alt="Invest Australia Alliance" class="alliance-footer-logo">
        <p class="footer-brand-name">Invest Australia Alliance&trade;</p>
        <p class="footer-ack">Connecting international industry with Australian opportunity.</p>
      </div>
      <div class="footer-section">
        <h3>Alliance Enquiries</h3>
        <div class="footer-contact-item">
          <span class="material-symbols-outlined">mail</span>
          <a href="mailto:alliance@acestrategies.au">alliance@acestrategies.au</a>
        </div>
      </div>
      <div class="footer-section">
        <p class="footer-ack">We acknowledge the Traditional Owners of the land on which we work and recognise their continued custodianship and connection to the land, waters and community.</p>
        <div style="margin-top:24px;">
          <a href="/" class="iaa-footer-link">← Return to Ace Strategies</a>
        </div>
      </div>
      <div class="footer-section">
        <h3>Legal</h3>
        <a href="/legal/code-of-conduct/" class="iaa-footer-link" style="display:block;margin-bottom:8px;">Code of Conduct</a>
        <a href="/legal/privacy/" class="iaa-footer-link" style="display:block;margin-bottom:8px;">Privacy Policy</a>
        <a href="/legal/terms/" class="iaa-footer-link" style="display:block;">Terms of Use</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {% year %} Invest Australia Alliance. All rights reserved.</p>

      {# IAA Theme Toggle #}
      <div class="iaa-theme-toggle-wrapper">
        <div class="iaa-theme-toggle" role="switch" aria-checked="false" aria-label="Switch between dark and light theme" tabindex="0">
          <span class="iaa-theme-toggle__label">Dark</span>
          <div class="iaa-theme-toggle__track">
            <div class="iaa-theme-toggle__handle">
              <span class="iaa-theme-toggle__icon iaa-theme-toggle__icon--moon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-4.4 2.26 5.4 5.4 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
                </svg>
              </span>
              <span class="iaa-theme-toggle__icon iaa-theme-toggle__icon--sun">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 17.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
                </svg>
              </span>
            </div>
          </div>
          <span class="iaa-theme-toggle__label">Light</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script src="/src/assets/js/script.js" defer></script>
</body>
</html>
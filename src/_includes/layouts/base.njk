<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="/assets/css/ace.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body class="theme-dark">
<div class="noise-overlay"></div>
<div class="cursor"></div>
<div class="cursor-follower"></div>

{# =========================================================================
   NAVIGATION
   ========================================================================= #}
<nav class="nav">
  <a href="/" class="logo">
    <img src="/assets/repository/images/ui/aces-page-header-logo.svg" alt="Ace Strategies" height="36">
  </a>

  <ul class="nav-menu" id="nav-menu">
    <li><a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}">Home</a></li>
    <li><a href="/about/" class="nav-link {% if page.url == '/about/' %}active{% endif %}">About</a></li>
    <li><a href="/capabilities/" class="nav-link {% if page.url == '/capabilities/' %}active{% endif %}">Capabilities</a></li>
    <li><a href="/team/" class="nav-link {% if page.url == '/team/' %}active{% endif %}">Team</a></li>
    <li><a href="/cases/" class="nav-link {% if page.url == '/cases/' %}active{% endif %}">Cases</a></li>
    <li>
      <a href="/services/polling/" class="nav-link {% if page.url == '/services/polling/' %}active{% endif %}">
        <span class="short-text">Research</span>
        <span class="full-text">Research and Polling</span>
      </a>
    </li>
    <li><a href="/news/" class="nav-link {% if page.url == '/news/' %}active{% endif %}">News</a></li>
    <li><a href="/alliance/" class="nav-link {% if page.url == '/alliance/' %}active{% endif %}">Alliance</a></li>
    <li><a href="/contact/" class="nav-link {% if page.url == '/contact/' %}active{% endif %}">Contact</a></li>
  </ul>

  {# SEARCH TOGGLE #}
  <button class="search-toggle" aria-label="Search" aria-expanded="false" aria-controls="search-modal">
    <span class="material-symbols-outlined">search</span>
  </button>

  <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

{# =========================================================================
   SEARCH MODAL
   ========================================================================= #}
<div class="search-modal" id="search-modal" aria-hidden="true">
  <div class="search-modal__overlay"></div>
  <div class="search-modal__content">
    <div class="search-modal__header">
      <div class="search-input-wrapper">
        <span class="material-symbols-outlined search-icon">search</span>
        <input type="text" id="search-input" class="search-input" placeholder="Search Ace Strategies..." autocomplete="off">
        <button class="search-clear" id="search-clear" aria-label="Clear search" style="display: none;">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <button class="search-close" aria-label="Close search">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <div class="search-results" id="search-results">
      <div class="search-placeholder">
        <span class="material-symbols-outlined">search</span>
        <p>Start typing to search case studies, news, services, and team members...</p>
      </div>
    </div>
    <div class="search-footer">
      <span><kbd>↑</kbd> <kbd>↓</kbd> to navigate</span>
      <span><kbd>↵</kbd> to select</span>
      <span><kbd>esc</kbd> to close</span>
    </div>
  </div>
</div>

{# =========================================================================
   MAIN CONTENT
   ========================================================================= #}
<main>
  {{ content | safe }}
</main>

{# =========================================================================
   FOOTER
   ========================================================================= #}
<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-grid">

      {# Column 1: Brand + Acknowledgement #}
      <div class="footer-section">
        <img src="/assets/repository/images/ui/logo/img-logo-nav-two.png" alt="Ace Strategies" class="footer-logo">
        <p class="footer-brand-name">Australian Communications &amp; Engagement Strategies&trade;</p>
        <p class="footer-abn">ABN: {{ site.abn }}</p>
        <div class="footer-acknowledgement">
          <p>We acknowledge the Traditional Owners of the land on which we work and recognise their continued custodianship and connection to the land, waters and community.</p>
        </div>
        <div class="footer-alliance-block">
          <span class="footer-alliance-label">Founding Member of</span>
          <a href="/alliance/" class="alliance-link">
            <img src="/assets/repository/images/ui/logo/img-logo-alliance-partner.png" alt="Invest Australia Alliance" style="height:45px;width:auto;display:block;">
          </a>
        </div>
      </div>

      {# Column 2: Capabilities #}
      <div class="footer-section">
        <h3>Capabilities</h3>
        <a href="/services/public-affairs/">Government Relations</a>
        <a href="/services/stakeholder-engagement/">Stakeholder Engagement</a>
        <a href="/services/strategic-communications/">Strategic Communications</a>
        <a href="/services/media-management/">Media Management</a>
        <a href="/services/polling/">Research and Polling</a>
        <a href="/services/new-market-entry/">Market Entry &amp; Growth</a>
      </div>

      {# Column 3: Explore #}
      <div class="footer-section">
        <h3>Explore</h3>
        <a href="/">Home</a>
        <a href="/about/">About Us</a>
        <a href="/capabilities/">Capabilities</a>
        <a href="/team/">Our Team</a>
        <a href="/cases/">Cases</a>
        <a href="/news/">News</a>
        <a href="/newsletters/">Newsletter Archive</a>
        <a href="/alliance/"><strong>Invest Australia Alliance</strong></a>
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer" class="footer-linkedin-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
          </svg>
          Follow our updates
        </a>
      </div>

      {# Column 4: Contact + Newsletter #}
      <div class="footer-section">
        <h3>Contact</h3>
        <div class="footer-contact-item">
          <span class="material-symbols-outlined">location_on</span>
          <p>Head Office<br>PO Box 104 Walkerville<br>SA 5081 Australia</p>
        </div>
        <div class="footer-contact-item">
          <span class="material-symbols-outlined">mail</span>
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </div>
        <div class="footer-contact-item">
          <span class="material-symbols-outlined">call</span>
          <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a>
        </div>

        {# NEWSLETTER SIGNUP — Compact Footer Version #}
        <div class="footer-newsletter">
          <h4>Stay informed</h4>
          <p>Market intelligence delivered monthly.</p>
          <form class="footer-newsletter-form" action="https://app.convertkit.com/forms/YOUR_FORM_ID/subscriptions" method="post">
            <input type="email" name="email_address" placeholder="Your email" aria-label="Email address" required>
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </div>
    </div>

    {# =========================================================================
       FOOTER BOTTOM — Copyright + Legal + Theme Toggle
       ========================================================================= #}
    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <p>&copy; {% year %} Ace Strategies. All rights reserved.</p>
        <div class="footer-bottom-links">
          <a href="/legal/code-of-conduct/">Code of Conduct</a>
          <a href="/legal/privacy/">Privacy Policy</a>
          <a href="/legal/terms/">Terms of Use</a>
        </div>
      </div>

      {# THEME TOGGLE — Material Design 3 #}
      <div class="theme-toggle-wrapper">
        <div class="theme-toggle" role="switch" aria-checked="false" aria-label="Switch between dark and light theme" tabindex="0">
          <span class="theme-toggle__label">Dark</span>
          <div class="theme-toggle__track">
            <div class="theme-toggle__handle">
              <span class="theme-toggle__icon theme-toggle__icon--moon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-4.4 2.26 5.4 5.4 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
                </svg>
              </span>
              <span class="theme-toggle__icon theme-toggle__icon--sun">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 17.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
                </svg>
              </span>
            </div>
          </div>
          <span class="theme-toggle__label">Light</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script src="/assets/js/script.js" defer></script>
</body>
</html>
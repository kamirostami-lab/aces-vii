---
layout: base.njk
title: Newsletter Archive
description: Past editions of the Ace Strategies monthly newsletter.
active_nav: /news/
permalink: /newsletters/index.html
---

<section class="news-hero" data-theme="dark">
  <div class="news-hero-content">
    <h1 class="hero-title">Newsletter <span style="font-family:var(--font-serif);font-style:italic;color:var(--sky-blue);">Archive</span></h1>
    <p class="hero-subtitle">Past editions of our monthly market intelligence briefing.</p>
  </div>
</section>

<section class="newsletter-archive" data-theme="light">
  <div class="archive-container">
    {% for newsletter in collections.newsletters %}
    <article class="newsletter-item">
      <div class="newsletter-date">{{ newsletter.data.date | dateFormat("long") }}</div>
      <h2><a href="{{ newsletter.url }}">{{ newsletter.data.title }}</a></h2>
      <p>{{ newsletter.data.excerpt }}</p>
      <a href="{{ newsletter.url }}" class="read-more">Read full edition →</a>
    </article>
    {% endfor %}
  </div>
</section>
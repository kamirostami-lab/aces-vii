<main class="iaa-canvas">
  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <span class="iaa-superhead">Members Only</span>
      <h1 class="iaa-display-title">Alliance Member Portal</h1>
      <p class="iaa-lead-text">Exclusive market intelligence, regulatory briefings, and partner resources.</p>
    </div>
  </section>

  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <h2 class="iaa-section-title">Latest Briefings</h2>

      <div class="member-resources-grid">
        <div class="member-resource-card">
          <span class="resource-badge">Q1 2026</span>
          <h3>Australian Market Outlook</h3>
          <p>Comprehensive analysis of economic indicators, policy direction, and sector opportunities.</p>
          <a href="/assets/repository/documents/members/q1-2026-outlook.pdf" class="btn-iaa-primary" download>
            Download PDF
          </a>
        </div>

        <div class="member-resource-card">
          <span class="resource-badge">Regulatory Update</span>
          <h3>FIRB Changes — What Partners Need to Know</h3>
          <p>Analysis of Foreign Investment Review Board reforms effective July 2026.</p>
          <a href="/assets/repository/documents/members/firb-update-2026.pdf" class="btn-iaa-primary" download>
            Download PDF
          </a>
        </div>

        <div class="member-resource-card">
          <span class="resource-badge">Polling Deep Dive</span>
          <h3>State-by-State Political Sentiment</h3>
          <p>Exclusive DemosAU polling with electorate-level modelling and analysis.</p>
          <a href="/assets/repository/documents/members/polling-deep-dive-mar2026.pdf" class="btn-iaa-primary" download>
            Download PDF
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <h2 class="iaa-section-title">Partner Directory</h2>

      <div class="iaa-index-wrapper">
        {% for partner in iaaPartners %}
        <div class="iaa-index-row">
          <div class="iaa-index-cat">{{ partner.category }}</div>
          <div class="iaa-index-name">{{ partner.name }}</div>
          <div class="iaa-index-desc">{{ partner.desc }}</div>
        </div>
        {% endfor %}
      </div>

      <div class="member-contact-note">
        <p>For direct partner introductions, contact <a href="mailto:alliance@acestrategies.au">alliance@acestrategies.au</a></p>
      </div>
    </div>
  </section>
</main>
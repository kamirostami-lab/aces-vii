---
layout: iaa-base.njk
title: Alliance Members Portal
description: Exclusive resources and insights for Invest Australia Alliance members.
permalink: /alliance/members/index.html
---

<main class="iaa-canvas">
  <header class="iaa-hero-editorial" style="min-height: 50vh;">
    <div class="iaa-hero-content" data-iaa-reveal>
      <span class="iaa-superhead">Members Portal</span>
      <h1 class="iaa-display-title">Alliance Resources</h1>
      <p class="iaa-lead-text">Exclusive market intelligence, regulatory updates, and strategic briefings for Invest Australia Alliance members.</p>
    </div>
  </header>
  
  <section class="iaa-editorial-section">
    <div class="iaa-container">
      <div class="iaa-section-intro" data-iaa-reveal>
        <span class="iaa-superhead">Welcome</span>
        <h2 class="iaa-section-title">Member Dashboard</h2>
        <p class="iaa-section-desc">Access your exclusive Alliance resources below. New materials are added monthly.</p>
      </div>
      
      <div class="iaa-grid-3" style="margin-top: 40px;">
        <div class="iaa-grid-item" style="border-top-color: var(--iaa-gold-dark);">
          <h3 class="iaa-item-title">Market Intelligence Briefings</h3>
          <p class="iaa-item-text">Quarterly reports on Australian market conditions, regulatory changes, and sector opportunities.</p>
          <a href="#" class="btn-iaa-text" style="margin-top: 16px; display: inline-block;">Access briefings &rarr;</a>
        </div>
        <div class="iaa-grid-item" style="border-top-color: var(--iaa-gold-dark);">
          <h3 class="iaa-item-title">Regulatory Updates</h3>
          <p class="iaa-item-text">Timely analysis of FIRB decisions, taxation changes, and compliance requirements.</p>
          <a href="#" class="btn-iaa-text" style="margin-top: 16px; display: inline-block;">View updates &rarr;</a>
        </div>
        <div class="iaa-grid-item" style="border-top-color: var(--iaa-gold-dark);">
          <h3 class="iaa-item-title">Partner Directory</h3>
          <p class="iaa-item-text">Complete contact directory of Alliance partners with service capabilities and regional coverage.</p>
          <a href="#" class="btn-iaa-text" style="margin-top: 16px; display: inline-block;">View directory &rarr;</a>
        </div>
      </div>
    </div>
  </section>
  
  <section class="iaa-editorial-section" style="background: rgba(0,0,0,0.02);">
    <div class="iaa-container">
      <span class="iaa-superhead" data-iaa-reveal>Recent Resources</span>
      <h2 class="iaa-section-title" data-iaa-reveal>Latest Member Materials</h2>
      
      <div style="margin-top: 40px;">
        {% for resource in resources %}
        <div style="padding: 24px 0; border-bottom: 1px solid var(--iaa-border); display: flex; align-items: center; gap: 24px; flex-wrap: wrap;">
          <span class="material-symbols-outlined" style="color: var(--iaa-gold-dark);">{{ resource.icon | default('description') }}</span>
          <div style="flex: 1;">
            <h4 style="font-size: 1.1rem; font-weight: 500; margin-bottom: 4px;">{{ resource.title }}</h4>
            <p style="font-size: 0.9rem; opacity: 0.7;">{{ resource.desc }}</p>
          </div>
          <a href="{{ resource.file_url }}" class="btn-iaa-text" download>Download</a>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
</main>
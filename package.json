{
  "name": "ace-strategies-platform",
  "version": "2.0.0",
  "description": "Ace Strategies — Communications & Engagement Platform",
  "scripts": {
    "build": "eleventy && pagefind --site _site --output-path _site/pagefind",
    "start": "eleventy --serve",
    "clean": "rm -rf _site",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "html-minifier-terser": "^7.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "wrangler": "^4.83.0"
  }
}

{
  "name": "ace-strategies-platform",
  "version": "2.0.0",
  "description": "Ace Strategies — Communications & Engagement Platform",
  "scripts": {
    "build": "eleventy && pagefind --site _site --output-path _site/pagefind",
    "start": "eleventy --serve",
    "clean": "rm -rf _site",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^4.0.2",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "@quasibit/eleventy-plugin-schema": "^1.13.0",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
    "chart.js": "^4.4.0",
    "google-spreadsheet": "^4.1.0",
    "html-minifier-terser": "^7.2.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^8.6.7"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "wrangler": "^4.82.1"
  }
}
